{"params":"<p>rightWidth<\/p><p>left<\/p><p>right<\/p>","items":{"4":{"type":"action","content":"<p>container.style.display = \"block\";<\/p><p>container.style.whiteSpace = \"nowrap\"<\/p><p><br \/><\/p><p>right.style.width = rightWidth + \"px\";<\/p><p>right.style.minWidth = rightWidth + \"px\";<\/p><p>right.style.marginLeft = \"5px\"<\/p>","one":"8"},"8":{"type":"action","content":"<p>left.width = 100% - (rightWidth + 5) px<\/p>","one":"9"},"1":{"type":"end"},"5":{"type":"action","content":"<p>add<\/p><ul><li>container: container<\/li><li>element: left<\/li><\/ul>","one":"6"},"2":{"type":"branch","one":"3","branchId":0},"6":{"type":"action","content":"<p>add<\/p><ul><li>container: container<\/li><li>element: right<\/li><\/ul>","one":"4"},"9":{"type":"action","content":"<p>return container<\/p>","one":"1"},"3":{"type":"action","content":"<p>container = create div<\/p>","one":"5"}},"type":"drakon"}