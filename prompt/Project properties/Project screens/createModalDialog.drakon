{"items":{"4":{"type":"action","content":"<p>clear(central)<\/p>","one":"5"},"8":{"type":"action","content":"<p>dialog.style =<\/p><ul><li>background: white<\/li><li>width: 500px<\/li><li>max width: screen width<\/li><li>horizontal position: center<\/li><li>vertical position: top<\/li><li>vertical scrollbars: auto<\/li><li>padding: 20px<\/li><\/ul>","one":"10"},"1":{"type":"end"},"5":{"type":"action","content":"<p>background = create div<\/p><ul><li>parent: central<\/li><\/ul>","one":"6"},"9":{"type":"action","content":"<p>return dialog<\/p>","one":"1"},"6":{"type":"action","content":"<p>background.style =<\/p><ul><li>background: 50% transparent black<\/li><li>no scroll bars<\/li><li>takes the whole screen<\/li><\/ul>","one":"7"},"11":{"type":"action","content":"<p>central.style.display = \"block\"<\/p>","one":"4"},"3":{"type":"action","content":"<p>central = get element by id (\"central\")<\/p>","one":"11"},"7":{"type":"action","content":"<p>dialog = create div<\/p><ul><li>parent: central<\/li><\/ul>","one":"8"},"2":{"type":"branch","one":"3","branchId":0},"10":{"type":"action","content":"<p>add \"pp-central-dialog\" to dialog.classes<\/p>","one":"9"}},"type":"drakon"}